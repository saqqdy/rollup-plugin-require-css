{
	"name": "rollup-plugin-require-css",
	"description": "A powerful rollup plugin for importing CSS with CSS Modules, preprocessors, and more",
	"version": "1.0.0",
	"packageManager": "pnpm@9.15.9",
	"type": "module",
	"main": "dist/index.cjs",
	"module": "dist/index.mjs",
	"types": "dist/index.d.mts",
	"exports": {
		".": {
			"types": {
				"import": "./dist/index.d.mts",
				"require": "./dist/index.d.cts"
			},
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		}
	},
	"engines": {
		"node": ">=12"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs",
		"deploy": "sh scripts/deploy.sh",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"pub": "tscjs scripts/publish",
		"unpub": "tscjs scripts/unpublish",
		"sync": "tscjs scripts/sync",
		"lint": "eslint --fix",
		"dist": "pnpm run lint && pnpm run build",
		"prepublishOnly": "pnpm run build"
	},
	"dependencies": {
		"@rollup/pluginutils": "^5.1.4"
	},
	"devDependencies": {
		"@eslint-sets/eslint-config": "^6.2.0",
		"@types/node": "^25.6.0",
		"@vitest/coverage-v8": "^3.2.4",
		"eslint": "^9.39.4",
		"rollup": "^4.59.1",
		"tsdown": "^0.21.4",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitepress": "^1.6.4",
		"vitest": "^3.2.4"
	},
	"peerDependencies": {
		"less": ">=4.0.0",
		"mount-style": ">=1.0.0",
		"postcss": ">=8.0.0",
		"rollup": ">=2.0.0",
		"sass": ">=1.0.0",
		"stylus": ">=0.55.0"
	},
	"peerDependenciesMeta": {
		"less": {
			"optional": true
		},
		"mount-style": {
			"optional": true
		},
		"postcss": {
			"optional": true
		},
		"sass": {
			"optional": true
		},
		"stylus": {
			"optional": true
		}
	},
	"keywords": [
		"rollup",
		"rollup-plugin",
		"css",
		"import-css",
		"require-css",
		"inject-css",
		"bundler",
		"vite",
		"typescript",
		"css-modules",
		"sass",
		"scss",
		"less",
		"stylus",
		"postcss",
		"sourcemap",
		"hmr",
		"minify",
		"code-splitting"
	],
	"sideEffects": false,
	"license": "MIT",
	"author": "saqqdy <https://github.com/saqqdy>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/saqqdy/rollup-plugin-require-css.git"
	},
	"bugs": {
		"url": "https://github.com/saqqdy/rollup-plugin-require-css/issues"
	},
	"homepage": "https://github.com/saqqdy/rollup-plugin-require-css#readme"
}
